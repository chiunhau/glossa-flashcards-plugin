{
	"manifest_version": 3,
	"name": "Glossa Flashcards for Obsidian",
	"version": "0.1.0",
	"description": "Turn any text into living vocabulary in Obsidian.",
	"permissions": ["contextMenus", "activeTab"],
	"icons": {
		"16": "icons/icon16.png",
		"32": "icons/icon32.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	},
	"action": {
		"default_icon": {
			"16": "icons/icon16.png",
			"32": "icons/icon32.png",
			"48": "icons/icon48.png",
			"128": "icons/icon128.png"
		}
	},
	"background": {
		"service_worker": "background.js"
	}
}
